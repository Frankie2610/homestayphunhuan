# Firebase Admin (bắt buộc cho chatbot và dữ liệu realtime)
FIREBASE_PROJECT_ID=homestay3caynon
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=homestay3caynon.firebaseapp.com
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://homestay3caynon-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=homestay3caynon.firebasestorage.app

# Có thể dùng một biến JSON thay cho ba biến credential phía trên
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"..."}

# Gemini (tùy chọn; tắt thì bot vẫn dùng logic lịch/giá có sẵn)
GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_MAX_OUTPUT_TOKENS=220
BOT_BRAND_NAME=Homestay Phú Nhuận

# Messenger (chỉ cần nếu vẫn dùng bot Facebook)
META_PAGE_ACCESS_TOKEN=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_GRAPH_VERSION=v25.0

# Website và thông tin vận hành
PUBLIC_SITE_URL=https://homestayphunhuan.vercel.app
BOT_SUPPORT_PHONE=0933882896
BOT_HOME_ADDRESS=26/10 Lê Văn Sỹ, Quận Phú Nhuận, TP.HCM
BOT_MAP_URL=https://www.google.com/maps/search/?api=1&query=26%2F10%20L%C3%AA%20V%C4%83n%20S%E1%BB%B9%2C%20Qu%E1%BA%ADn%20Ph%C3%BA%20Nhu%E1%BA%ADn%2C%20TP.HCM
BOT_TIMEZONE=Asia/Ho_Chi_Minh

# Cảnh báo Telegram (tùy chọn)
BOT_TELEGRAM_TOKEN=
BOT_TELEGRAM_CHAT_ID=
