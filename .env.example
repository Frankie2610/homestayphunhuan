# Firebase Admin
# Có thể dùng một JSON service account thay cho 3 biến project/client/private bên dưới.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=

# Meta Messenger
META_VERIFY_TOKEN=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
META_GRAPH_VERSION=v25.0

# Gemini (optional)
GEMINI_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT_MS=5000
GEMINI_MAX_OUTPUT_TOKENS=180

# Public chatbot settings
PUBLIC_SITE_URL=https://homestayphunhuan.vercel.app
WEB_CHAT_ALLOWED_ORIGINS=https://homestayphunhuan.vercel.app
BOT_BRAND_NAME=Homestay Quận Phú Nhuận
BOT_SUPPORT_PHONE=0933882896
BOT_HOME_ADDRESS=Quận Phú Nhuận, TP.HCM
BOT_MAP_URL=https://www.google.com/maps/search/?api=1&query=Qu%E1%BA%ADn+Ph%C3%BA+Nhu%E1%BA%ADn%2C+TP.HCM

# Website chatbot performance
# true: câu trả lời nghiệp vụ dùng logic/Firebase trực tiếp, không chờ Gemini viết lại lần 2
WEB_CHAT_FAST_MODE=true
WEB_CHAT_GEMINI_REWRITE=true
WEB_CHAT_CACHE_TTL_MS=600000
WEB_CHAT_DATA_CACHE_TTL_MS=15000
WEB_CHAT_FIREBASE_READ_TIMEOUT_MS=8000
WEB_CHAT_PROCESSING_TIMEOUT_MS=28000

# Firebase Web config cho trình duyệt. /api/public-config hỗ trợ cả tên FIREBASE_* và PUBLIC_FIREBASE_*.
# FIREBASE_DATABASE_URL và FIREBASE_PROJECT_ID ở trên được dùng chung cho backend + frontend.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=homestay3caynon-e00de.firebaseapp.com
FIREBASE_STORAGE_BUCKET=homestay3caynon-e00de.firebasestorage.app

# Có thể dùng các alias PUBLIC_* thay cho 3 biến ngay trên nếu muốn phân biệt rõ config public.
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_DATABASE_URL=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=

# Protect diagnostics endpoint
BOT_HEALTH_SECRET=
